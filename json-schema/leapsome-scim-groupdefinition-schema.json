{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SCIM GroupDefinition",
  "description": "Describes the group to create",
  "type": "object",
  "properties": {
    "displayName": {
      "description": "The group's display name",
      "type": "string"
    },
    "externalId": {
      "type": "string",
      "description": "The id of the group in an external system"
    }
  },
  "required": [
    "displayName"
  ]
}